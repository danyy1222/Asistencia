<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=DM+Mono:wght@400;500&display=swap');
:root {
  --bg: #0b1020;
  --panel: #111a31;
  --accent: #22c55e;
  --text: #e5e7eb;
  --muted: #94a3b8;
}
* { box-sizing: border-box; }
body {
  margin: 0;
  font-family: "Space Grotesk", system-ui, sans-serif;
  color: var(--text);
  background: radial-gradient(900px 480px at 15% -5%, #1f2a44 0%, transparent 60%),
              radial-gradient(900px 400px at 90% 10%, #1a2b5a 0%, transparent 55%),
              var(--bg);
  min-height: 100vh;
}
.wrap {
  max-width: 520px;
  margin: 0 auto;
  padding: 28px 18px 48px;
}
.card {
  background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01));
  border: 1px solid rgba(148,163,184,0.2);
  border-radius: 22px;
  padding: 22px;
  box-shadow: 0 12px 40px rgba(0,0,0,0.35);
}
.title {
  margin: 0 0 6px;
  font-size: 24px;
  font-weight: 700;
}
.subtitle {
  color: var(--muted);
  font-size: 13px;
  margin-bottom: 18px;
}
input {
  width: 100%;
  padding: 14px 12px;
  border-radius: 12px;
  border: 1px solid rgba(148,163,184,0.25);
  background: #0f1527;
  color: var(--text);
  font-size: 15px;
}
input::placeholder { color: #94a3b8; }
button {
  width: 100%;
  padding: 13px 16px;
  border: none;
  border-radius: 12px;
  background: var(--accent);
  color: #0b1020;
  font-weight: 700;
  font-size: 16px;
  margin-top: 14px;
  cursor: pointer;
  box-shadow: 0 8px 20px rgba(34,197,94,0.25);
}
</style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <h2 class="title">Registrar asistencia</h2>
      <div class="subtitle">Completa tu nombre para quedar registrado</div>

      <form method="POST" action="/registrar">
        <input name="nombre" placeholder="Tu nombre" required>
        <input type="hidden" name="sesion" value="<%= sesion %>">
        <input type="hidden" name="ip" id="ip">
        <button>Registrar</button>
      </form>
    </div>
  </div>

  <script>
  fetch("https://api.ipify.org?format=json")
  .then(r=>r.json())
  .then(d=>{
    document.getElementById("ip").value = d.ip;
  });
  </script>
</body>
</html>